{
  "title": "Anki Sync Server",
  "uid": "anki-sync-server",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Users",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "anki_sync_users_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] }
    },
    {
      "id": 2, "type": "stat", "title": "Sync Data",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "anki_sync_data_bytes", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] }
    },
    {
      "id": 3, "type": "stat", "title": "Total Syncs",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "anki_sync_operations_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] }
    },
    {
      "id": 4, "type": "stat", "title": "Backups",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "anki_sync_backup_count", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] }
    },
    {
      "id": 5, "type": "stat", "title": "Last Backup Age",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "time() - anki_sync_backup_last_timestamp_seconds > 0 or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null }, { "color": "orange", "value": 172800 }, { "color": "red", "value": 604800 } ] } }, "overrides": [] }
    },
    {
      "id": 6, "type": "stat", "title": "Failed Logins (total)",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "anki_sync_auth_failed_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 } ] } }, "overrides": [] }
    },
    {
      "id": 7, "type": "timeseries", "title": "Syncs per hour",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "increase(anki_sync_operations_total[1h])", "legendFormat": "syncs", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1 }, "min": 0, "decimals": 0 }, "overrides": [] },
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Request latency (recent window)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "anki_sync_request_latency_ms", "legendFormat": "{{stat}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0 }, "min": 0 }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 9, "type": "timeseries", "title": "Login attempts per hour",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(anki_sync_auth_success_total[1h])", "legendFormat": "success", "refId": "A" },
        { "expr": "increase(anki_sync_auth_failed_total[1h])", "legendFormat": "failed", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }, "min": 0, "decimals": 0 }, "overrides": [ { "matcher": { "id": "byName", "options": "failed" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 10, "type": "bargauge", "title": "Data per user",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "anki_sync_user_data_bytes", "legendFormat": "{{user}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "blue" }, "min": 0 }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "basic", "showUnfilled": true }
    },
    {
      "id": 11, "type": "bargauge", "title": "Devices per user",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "anki_sync_devices_total", "legendFormat": "{{user}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "blue" }, "min": 0, "decimals": 0 }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "basic", "showUnfilled": true }
    }
  ]
}
